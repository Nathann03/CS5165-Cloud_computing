APP_NAME=Retail Analytics Cloud Project
ENVIRONMENT=development
DATABASE_URL=sqlite:///data/db/retail_analytics.db
ADMIN_TOKEN=change-this-admin-token
AUTO_LOAD_ON_STARTUP=1
STARTUP_TRANSACTION_LIMIT=20000
SECRET_KEY=change-me
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=retail-datasets
AZURE_BLOB_HOUSEHOLDS_BLOB=400_households.csv
AZURE_BLOB_PRODUCTS_BLOB=400_products.csv
AZURE_BLOB_TRANSACTIONS_BLOB=400_transactions.csv
HOUSEHOLDS_CSV=data/uploads/azure_minimum/400_households_min10k.csv
PRODUCTS_CSV=data/uploads/azure_minimum/400_products_min10k.csv
TRANSACTIONS_CSV=data/uploads/azure_minimum/400_transactions_min10k.csv
